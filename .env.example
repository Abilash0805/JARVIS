# Copy this file to `.env` and fill in the keys for the providers you want.
# You only need keys for the providers you actually use; JARVIS skips any
# provider whose key is missing. Every provider below is free-tier.

# --- Groq --- https://console.groq.com (free tier)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- Cerebras --- https://cloud.cerebras.ai (free tier)
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gpt-oss-120b

# --- Mistral --- https://console.mistral.ai (free tier)
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# --- NVIDIA NIM (Nemotron) --- https://build.nvidia.com (free API key)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# --- Default provider JARVIS uses for its own reasoning ---
# One of: groq | cerebras | mistral | nvidia
# (All configured providers are also used as automatic fallbacks when a free
#  tier rate-limits, so JARVIS keeps working.)
JARVIS_DEFAULT_PROVIDER=groq

# --- Vision (free vision models) ---
# Which provider's key/endpoint to use for image understanding (groq | nvidia).
JARVIS_VISION_PROVIDER=groq
# Optional override of the vision model id.
# JARVIS_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Autonomy / safety ---
# JARVIS runs autonomously by default (no confirmation prompts) so it can build
# whole websites, decks, PDFs and study packs end to end without interruption.
# Set to true to be asked before each shell command / file write / PC action.
JARVIS_REQUIRE_CONFIRMATION=false
# A tiny accident guard still blocks catastrophic commands (rm -rf /, mkfs,
# fork bombs, format c:, ...). Set to true to remove even that last guard.
JARVIS_DISABLE_BLOCKLIST=false
# Optionally confine filesystem tools (read/write/append/delete/list) to a
# directory tree, e.g. /home/you/jarvis_workspace. Leave blank for no
# confinement (full access to whatever the OS user can touch).
JARVIS_FS_ROOT=
